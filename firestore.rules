rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
//  CourtPals Firestore Security Rules
//
//  Model (shared court with invite code):
//    /users/{uid}                       — private profile, self-owned
//    /invites/{inviteCode}              — code → courtId lookup
//    /courts/{courtId}                  — a court's metadata + members[]
//        /players/{playerId}            — roster
//        /sessions/{sessionId}          — saved Saturdays (history)
//        /liveMatch/{docId}             — current scoreboard (public read)
//
//  Paste these rules into Firebase Console → Firestore Database → Rules
//  for database id `courtpaldev` (or the default database).
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(courtId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/courts/$(courtId))
        && request.auth.uid in
           get(/databases/$(database)/documents/courts/$(courtId)).data.members;
    }

    // ── Per-user profile (linked to Firebase uid) ───────────────────────────
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Invite code → courtId lookup ────────────────────────────────────────
    // Any signed-in user can resolve a specific code by id to find their court.
    // Listing every invite is denied so codes can't be scraped. Writes are
    // restricted to the admin/host path (or provisioned via the Console).
    match /invites/{inviteCode} {
      allow get: if isSignedIn();
      allow list: if false;
      allow write: if isSignedIn()
        && request.auth.uid ==
           get(/databases/$(database)/documents/courts/$(request.resource.data.courtId)).data.createdBy;
    }

    // ── Courts ──────────────────────────────────────────────────────────────
    match /courts/{courtId} {
      // Fetch a specific court by id when signed in (needed for join flow).
      // Listing all courts is denied.
      allow get: if isSignedIn();
      allow list: if false;

      // Anyone signed-in can create a new court — they must be the creator
      // and appear in the initial members list.
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Updates:
      //   (a) The creator can edit anything.
      //   (b) Any signed-in user can add ONLY their own uid to members
      //       (the join-with-invite flow). The diff() check enforces that
      //       no other field changes on the court doc.
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid
        || (
          !(request.auth.uid in resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['members'])
        )
      );

      // Only the creator can delete a court.
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      // ── Roster (members only) ─────────────────────────────────────────────
      match /players/{playerId} {
        allow read, write: if isMember(courtId);
      }

      // ── Saved history (members only) ──────────────────────────────────────
      match /sessions/{sessionId} {
        allow read, write: if isMember(courtId);
      }

      // ── Active tournament (one doc per court at id 'current') ────────────
      // Any court member can read. Create is allowed only when no doc exists
      // (Firestore's built-in behaviour for the create rule) and the caller
      // stamps themselves as createdBy. Updates + deletes are gated on the
      // createdBy field, so only the original starter of the tournament can
      // progress or end it.
      match /tournaments/{docId} {
        allow read: if isMember(courtId);
        allow create: if isMember(courtId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isMember(courtId)
          && resource.data.createdBy == request.auth.uid;
        allow delete: if isMember(courtId)
          && resource.data.createdBy == request.auth.uid;
      }

      // ── Live scoreboard (public read for spectators, members write) ───────
      match /liveMatch/{docId} {
        allow read: if true;
        allow write: if isMember(courtId);
      }
    }
  }
}
